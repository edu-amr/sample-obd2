{
  "name": "obd-node",
  "version": "1.0.0",
  "description": "A Node.js library for communicating with OBD2 (On-Board Diagnostics) systems in vehicles",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prepublishOnly": "npm run build",
    "example": "node examples/basic-usage.js"
  },
  "keywords": [
    "obd2",
    "obd",
    "obdii",
    "elm327",
    "bluetooth",
    "serial",
    "vehicle",
    "diagnostics",
    "automotive",
    "car"
  ],
  "author": "Jacob Ross jacob.r@syntaxindustries.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jacobrsyntaxindustries/obd-node.git"
  },
  "bugs": {
    "url": "https://github.com/jacobrsyntaxindustries/obd-node/issues"
  },
  "homepage": "https://github.com/jacobrsyntaxindustries/obd-node#readme",
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/node": "^20.6.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.49.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "@serialport/parser-readline": "^12.0.0",
    "net": "^1.0.2",
    "serialport": "^12.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ]
}
